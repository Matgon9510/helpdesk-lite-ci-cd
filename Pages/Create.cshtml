@page
@model HelpDeskLite.Pages.CreateModel

        @{
        ViewData["Title"] = "Create";
            Layout = "~/Pages/Tickets/Create.cshtml";
        }
        
        <h1>Create</h1>
        
    <h4>Ticket</h4>
    <hr />
    <div class="row">
    <div class="col-md-4">
    <form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Ticket.Titulo" class="control-label"></label>
                <input asp-for="Ticket.Titulo" class="form-control" />
                <span asp-validation-for="Ticket.Titulo" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Ticket.Descripcion" class="control-label"></label>
                <input asp-for="Ticket.Descripcion" class="form-control" />
                <span asp-validation-for="Ticket.Descripcion" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Ticket.Prioridad" class="control-label"></label>
                <input asp-for="Ticket.Prioridad" class="form-control" />
                <span asp-validation-for="Ticket.Prioridad" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Ticket.Estado" class="control-label"></label>
                <input asp-for="Ticket.Estado" class="form-control" />
                <span asp-validation-for="Ticket.Estado" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Ticket.FechaCreacion" class="control-label"></label>
                <input asp-for="Ticket.FechaCreacion" class="form-control" />
                <span asp-validation-for="Ticket.FechaCreacion" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
