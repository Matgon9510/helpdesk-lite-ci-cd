@page "{id:int?}"
@model HelpDeskLite.Pages.Tickets.DetailsModel

@{
    ViewData["Title"] = "Detalles del ticket";
}

<h1>Detalles del ticket</h1>

<div>
    <h4>Información registrada</h4>
    <hr />

    <dl class="row">
        <dt class="col-sm-2">
            ID
        </dt>
        <dd class="col-sm-10">
            @Model.Ticket.Id
        </dd>

        <dt class="col-sm-2">
            Título
        </dt>
        <dd class="col-sm-10">
            @Model.Ticket.Titulo
        </dd>

        <dt class="col-sm-2">
            Descripción
        </dt>
        <dd class="col-sm-10">
            @Model.Ticket.Descripcion
        </dd>

        <dt class="col-sm-2">
            Prioridad
        </dt>
        <dd class="col-sm-10">
            @Model.Ticket.Prioridad
        </dd>

        <dt class="col-sm-2">
            Estado
        </dt>
        <dd class="col-sm-10">
            @Model.Ticket.Estado
        </dd>

        <dt class="col-sm-2">
            Fecha de creación
        </dt>
        <dd class="col-sm-10">
            @Model.Ticket.FechaCreacion.ToString("dd/MM/yyyy HH:mm")
        </dd>
    </dl>
</div>

<div>
    <a asp-page="./Edit" asp-route-id="@Model.Ticket.Id" class="btn btn-warning">Editar</a>
    <a asp-page="./Index" class="btn btn-secondary">Volver</a>
</div>