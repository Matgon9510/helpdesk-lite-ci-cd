@page "{id:int?}"
@model HelpDeskLite.Pages.Tickets.DeleteModel

@{
    ViewData["Title"] = "Eliminar ticket";
}

<h1>Eliminar ticket</h1>

<h4>¿Está seguro que desea eliminar este ticket?</h4>
<hr />

<div class="alert alert-warning">
    Esta acción eliminará el ticket de la base de datos.
</div>

<dl class="row">
    <dt class="col-sm-2">
        ID
    </dt>
    <dd class="col-sm-10">
        @Model.Ticket.Id
    </dd>

    <dt class="col-sm-2">
        Título
    </dt>
    <dd class="col-sm-10">
        @Model.Ticket.Titulo
    </dd>

    <dt class="col-sm-2">
        Descripción
    </dt>
    <dd class="col-sm-10">
        @Model.Ticket.Descripcion
    </dd>

    <dt class="col-sm-2">
        Prioridad
    </dt>
    <dd class="col-sm-10">
        @Model.Ticket.Prioridad
    </dd>

    <dt class="col-sm-2">
        Estado
    </dt>
    <dd class="col-sm-10">
        @Model.Ticket.Estado
    </dd>

    <dt class="col-sm-2">
        Fecha de creación
    </dt>
    <dd class="col-sm-10">
        @Model.Ticket.FechaCreacion.ToString("dd/MM/yyyy HH:mm")
    </dd>
</dl>

<form method="post">
    <input type="hidden" asp-for="Ticket.Id" />

    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-page="./Index" class="btn btn-secondary">Cancelar</a>
</form>