@page
@model HelpDeskLite.Pages.Tickets.IndexModel

@{
    ViewData["Title"] = "Tickets de soporte";
}

<h1>Tickets de soporte</h1>

<p class="text-muted">
    Módulo de gestión de tickets con filtros por estado, prioridad y búsqueda por texto.
</p>

<div class="card mb-4 shadow-sm">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Buscar</label>
                <input name="Busqueda" value="@Model.Busqueda" class="form-control" placeholder="Buscar por título o descripción" />
            </div>

            <div class="col-md-3">
                <label class="form-label">Estado</label>
                <select name="EstadoFiltro" class="form-select">
                    <option value="">Todos</option>
                    <option value="Abierto" selected="@(Model.EstadoFiltro == "Abierto")">Abierto</option>
                    <option value="En proceso" selected="@(Model.EstadoFiltro == "En proceso")">En proceso</option>
                    <option value="Cerrado" selected="@(Model.EstadoFiltro == "Cerrado")">Cerrado</option>
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Prioridad</label>
                <select name="PrioridadFiltro" class="form-select">
                    <option value="">Todas</option>
                    <option value="Baja" selected="@(Model.PrioridadFiltro == "Baja")">Baja</option>
                    <option value="Media" selected="@(Model.PrioridadFiltro == "Media")">Media</option>
                    <option value="Alta" selected="@(Model.PrioridadFiltro == "Alta")">Alta</option>
                </select>
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">Filtrar</button>
            </div>
        </form>

        <div class="mt-3">
            <a class="btn btn-outline-secondary btn-sm" asp-page="/Tickets/Index">Limpiar filtros</a>
        </div>
    </div>
</div>

<p>
    <a class="btn btn-success" asp-page="/Tickets/Create">Crear nuevo ticket</a>
</p>

<div class="alert alert-info">
    Total de tickets encontrados: <strong>@Model.Tickets.Count</strong>
</div>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Título</th>
            <th>Descripción</th>
            <th>Prioridad</th>
            <th>Estado</th>
            <th>Fecha</th>
            <th>Cambiar estado</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var ticket in Model.Tickets)
        {
            <tr>
                <td>@ticket.Id</td>
                <td>@ticket.Titulo</td>
                <td>@ticket.Descripcion</td>

                <td>
                    @if (ticket.Prioridad == "Alta")
                    {
                        <span class="badge bg-danger">Alta</span>
                    }
                    else if (ticket.Prioridad == "Media")
                    {
                        <span class="badge bg-warning text-dark">Media</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Baja</span>
                    }
                </td>

                <td>
                    @if (ticket.Estado == "Abierto")
                    {
                        <span class="badge bg-primary">Abierto</span>
                    }
                    else if (ticket.Estado == "En proceso")
                    {
                        <span class="badge bg-info text-dark">En proceso</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Cerrado</span>
                    }
                </td>

                <td>@ticket.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</td>

                <td>
                    <form method="post" asp-page-handler="CambiarEstado">
                        <input type="hidden" name="id" value="@ticket.Id" />

                        <select name="estado" class="form-select form-select-sm">
                            <option value="Abierto">Abierto</option>
                            <option value="En proceso">En proceso</option>
                            <option value="Cerrado">Cerrado</option>
                        </select>

                        <button type="submit" class="btn btn-sm btn-outline-success mt-1">
                            Actualizar
                        </button>
                    </form>
                </td>

                <td>
                    <a asp-page="./Edit" asp-route-id="@ticket.Id" class="btn btn-sm btn-warning">Editar</a>
                    <a asp-page="./Details" asp-route-id="@ticket.Id" class="btn btn-sm btn-info">Detalles</a>
                    <a asp-page="./Delete" asp-route-id="@ticket.Id" class="btn btn-sm btn-danger">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>